# =============================================================================
# Rootstock Omni-Key – Environment variables (contracts)
# =============================================================================
# Copy this file to .env in this folder and fill in your values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment – used by: forge script script/Deploy.s.sol
# -----------------------------------------------------------------------------

# Private key of the account that will pay gas and deploy the contracts.
# No leading 0x. Example: 0x1234...abcd
DEPLOYER_PRIVATE_KEY=

# Address that will control the SmartAccount (owner of the Bitcoin key).
# This is the Ethereum-style address derived from the Bitcoin public key.
# Example: 0x742d35Cc6634C0532925a3b844Bc454e4438f44e
SMART_ACCOUNT_OWNER=

# Relayer wallet address (optional). Required for Unisat/Bitcoin-style signing.
# Set to the address that has RELAYER_PRIVATE_KEY in relayer/.env. Use 0x0000000000000000000000000000000000000000 to disable.
# RELAYER_ADDRESS=

# Rootstock RPC URL. Use testnet for development, mainnet for production.
# Testnet:  https://public-node.testnet.rsk.co   (Chain ID: 31)
# Mainnet:  https://public-node.rsk.co          (Chain ID: 30)
ROOTSTOCK_RPC_URL=https://public-node.testnet.rsk.co

# -----------------------------------------------------------------------------
# Relayer (optional – for later)
# -----------------------------------------------------------------------------
# RELAYER_PORT=3001
# RELAYER_ROOTSTOCK_RPC_URL=https://public-node.testnet.rsk.co

# -----------------------------------------------------------------------------
# Demo app (optional – for later)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_RELAYER_URL=http://localhost:3001
# NEXT_PUBLIC_SMART_ACCOUNT_ADDRESS=
# NEXT_PUBLIC_COUNTER_ADDRESS=
