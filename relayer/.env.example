# =============================================================================
# Rootstock Omni-Key – Relayer environment variables
# =============================================================================
# Copy to .env and fill in. Never commit .env.
# =============================================================================

# Rootstock RPC URL (testnet or mainnet)
ROOTSTOCK_RPC_URL=https://public-node.testnet.rsk.co

# Relayer wallet private key (pays gas). No 0x prefix.
RELAYER_PRIVATE_KEY=

# Default SmartAccount contract address (optional if frontend always sends smartAccount)
# SMART_ACCOUNT_ADDRESS=0x78cb47B2C97922471435d516D17a448BB74015B0

# Server port
PORT=3001
