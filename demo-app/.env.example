# =============================================================================
# Omni Counter demo dApp – environment variables
# =============================================================================
# Copy to .env.local and fill in. Used at build time and in the browser.
# =============================================================================

# Relayer base URL (must be reachable from the user's browser)
NEXT_PUBLIC_RELAYER_URL=http://localhost:3001

# Rootstock RPC (testnet or mainnet)
NEXT_PUBLIC_RPC_URL=https://public-node.testnet.rsk.co

# Deployed contract addresses (from your contracts deployment)
NEXT_PUBLIC_SMART_ACCOUNT_ADDRESS=0x78cb47B2C97922471435d516D17a448BB74015B0
NEXT_PUBLIC_COUNTER_ADDRESS=0xf68d5923485aB66E9DFbA3E78e16A133F43Bc5ec
